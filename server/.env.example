# MongoDB Connection Configuration
# Replace the placeholder values with your actual MongoDB connection details.
MONGO_DB_USERNAME=your_mongodb_username
MONGO_DB_PASSWORD=your_mongodb_password
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.lipxyex.mongodb.net/?appName=Cluster0

# JSON Web Token Secret Key
# Change this to a secure random string for production environments.
JWT_SECRET=your_jwt_secret_key_here
